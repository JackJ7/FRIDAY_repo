# Derived data and logs are never versioned (spec §4).
data/
logs/
__pycache__/
*.pyc

# --- Python environments & test caches ---
.venv/
.venv-train/
venv/
env/
.pytest_cache/
.hypothesis/
*.egg-info/

# --- FRIDAY runtime domains ---
# brain/ is its OWN git repo (runtime auto-commits) — never nest it here.
brain/
# Her writable outbox domain — generated artifacts, not source.
friday_documents/
# Test-run outputs (regenerated by run_suite).
results/
# Runtime config side-effects (the live config itself IS tracked).
config/audit.log
config/*.last_loaded.yaml

# --- Autoresearch / test clones (each is an embedded git repo) ---
FRIDAY_repo/

# --- Large model & training artifacts (34 GB+; training/ SOURCE stays tracked) ---
training/gguf/
training/adapters/
unsloth_compiled_cache/

# --- Editor / tooling ---
.obsidian/
.claude/settings.local.json
